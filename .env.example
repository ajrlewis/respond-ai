# Core runtime
# APP_ENV is read by API settings; Docker Compose defaults to development unless you also
# pass APP_ENV through api/worker service environment.
APP_ENV=development
DATABASE_URL=postgresql+psycopg://respondai:respondai@postgres:5432/respondai
APP_REDIS_URL=redis://redis:6379/0
APP_CELERY_BROKER_URL=redis://redis:6379/1
APP_CELERY_RESULT_BACKEND=redis://redis:6379/2
LOGGING_LEVEL=INFO

# Provider API keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# AI provider routing
AI_PROVIDER=openai
LARGE_LLM_PROVIDER=openai
LARGE_LLM_MODEL=gpt-4o
SMALL_LLM_PROVIDER=openai
SMALL_LLM_MODEL=gpt-4o-mini
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
EVAL_LLM_PROVIDER=
EVAL_LLM_MODEL=

# AI behavior
AI_TEMPERATURE=0
AI_MAX_RETRIES=2
AI_TIMEOUT_SECONDS=60
ENABLE_LLM_JUDGE_EVALS=false
# MODEL_PRICING_JSON is used for cost estimation in API observability.
MODEL_PRICING_JSON={}

# Retrieval tuning
RETRIEVAL_TOP_K=10
FINAL_EVIDENCE_K=6

# Demo auth + web origin
APP_DEMO_USERNAME=admin
APP_DEMO_PASSWORD=admin1234
APP_SESSION_SECRET=respondai-demo-session-secret
APP_WEB_ORIGIN=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
